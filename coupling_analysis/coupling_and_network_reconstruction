%% Brain–heart–gut coupling and network reconstruction pipeline

% DOI:
% https://doi.org/10.64898/2026.04.15.718683
%
% Main analysis steps:
%
% - Load multimodal EEG, ECG, and EGG physiological markers timeseries 
% - Compute delayed coupling between physiological signals
% - Quantify nonlinear associations using the Maximal Information Coefficient (MIC)
% - Estimate coupling across extended temporal delay ranges
% - Generate IAAFT surrogate physiological signals
% - Perform surrogate-based statistical significance testing
% - Identify significant brain–heart, brain–gut, and heart–gut interactions
% - Estimate predominant interaction delays and directionality
% - Reconstruct large-scale electrophysiological interaction networks
%
% Physiological signals:
%
% - EEG alpha-band power
% - Cardiac sympathetic index (CSI)
% - Cardiac parasympathetic index (CVI/CPI)
% - Gastric rhythm power (EGG)
%
% Required external functions and libraries:
%
% - FieldTrip
% - MINEpy
% - build_graph.m
%
% The surrogate generation function sir_surriaafft.m was adapted from the
% SIR toolbox presented in:
%
% Sparacino L., Antonacci Y., Mijatovic G., Faes L. (2025)
% "Measuring hierarchically-organized interactions in dynamic networks
% through spectral entropy rates: Theory, estimation, and illustrative
% application to physiological networks

close all
clear all
clc
  
%%
%load data
load('X.mat');

Tmax   =120; %set delay range
lag_index = -Tmax:1:Tmax;

EEG_labels = { ...
    'Fp1','Fp2','F7','F3','Fz','F4','F8', ...
    'FC5','FC1','FC2','FC6', ...
    'T7','C3','Cz','C4','T8', ...
    'TP9','CP5','CP1','CP2','CP6','TP10', ...
    'P7','P3','Pz','P4','P8', ...
    'PO9','O1','Oz','O2','PO10' };

subjects=1:28 

Ntargets = 3;
Nsurr   =   100;
alpha = 0.05;

%init variables 
Nchan   = length(EEG_labels);
Nsubj   = length(subjects);

val_sign_all = zeros(Nsubj,Nchan,Ntargets);
delay_real_all= zeros(Nsubj,Nchan,Ntargets);


%% Brain - Body couplings 

for s = 1:Nsubj

    EEG = X(s).EEG;
    CSI = X(s).CSI;
    CVI = X(s).CVI;
    EGG = X(s).EGG;
    
    targets = [CSI; CVI; EGG];
    target_names = {'EEG–CSI','EEG–CVI','EEG–EGG'};

    val_real_subj = zeros(Nchan,Ntargets);
    val_surr_subj = zeros(Nchan,Ntargets,Nsurr);
    delay_real_subj = zeros(Nchan,Ntargets);


    for ch = 1:Nchan   
        
        fprintf('Subject %d – channel %d\n', s, ch);

        Xeeg = EEG(ch,:)';
     
       
   
        for t = 1:Ntargets
            
            Y = targets(t,:)';

            val_lag = mic_lagged_mine(Xeeg,Y,lag_index);
            [val_real_subj(ch,t),idx] = max(val_lag);
             delay_real_subj(ch,t) = lag_index(idx);
            
            % surrogate at best lag
            for is = 1:Nsurr

                Xs = sir_surriaafft(Xeeg);
                Ys = sir_surriaafft(Y);
                mic_s =mic_lagged_mine(Xs,Ys, delay_real_subj(ch,t));
                val_surr_subj(ch,t,is) = mic_s;

            end
        end
    end
    
    % statistical significance test 
    
    val_sig = zeros(Nchan,Ntargets);
    
    for ch = 1:Nchan
        for t = 1:Ntargets
            
            val_surr=squeeze(val_surr_subj(ch,t,:));
            p = sum( val_surr > val_real_subj(ch,t)) / Nsurr;
            if p < alpha
                val_sig(ch,t) = val_real_subj(ch,t);

            end
        end
    end

    val_sign_all(s,:,:) = val_sig;     
    delay_real_all(s,:,:) = delay_real_subj;

end


nLag  = length(lag_index);
nPairs = 2;   % EGG–CSI, EGG–CVI

%init group variables
mic_real_all_body  = zeros(Nsubj,nPairs,nLag);
mic_max_pos_body   = zeros(Nsubj,nPairs);
mic_max_neg_body   = zeros(Nsubj,nPairs);
lag_max_pos_body   = zeros(Nsubj,nPairs);
lag_max_neg_body   = zeros(Nsubj,nPairs);
mic_surr_pos_body  = zeros(Nsubj,nPairs,Nsurr);
mic_surr_neg_body  = zeros(Nsubj,nPairs,Nsurr);


for s = 1:Nsubj

    fprintf('Subject: %d ', s);
    
    CSI = X(s).CSI;
    CVI = X(s).CVI;
    EGG= X(s).EGG;

    X_EGG  = EGG';
    X_ECG = [CSI; CVI];

    for p = 1:nPairs
        
        y = X_ECG(p,:)';
    
        mic_lag_body = mic_lagged_mine(X_EGG, y,lag_index);
         mic_real_all_body(s,p,:) =  mic_lag_body;
    
        % positive delays
        lags_pos = lag_index(lag_index > 0);
        mic_pos  =  mic_lag_body(lag_index > 0);
    
        [mic_max_pos_body(s,p), ix_pos] = max(mic_pos);
        lag_max_pos_body(s,p) = lags_pos(ix_pos);
    
        % negative delays
        lags_neg = lag_index(lag_index < 0);
         mic_neg  =  mic_lag_body(lag_index < 0);
    
        [ mic_max_neg_body(s,p), ix_neg] = max(mic_neg);
        lag_max_neg_body(s,p) = lags_neg(ix_neg);

  
        lag_target_pos = lag_max_pos_body(s,p);
        lag_target_neg = lag_max_neg_body(s,p);

        for is = 1:Nsurr
            
            xs = sir_surriaafft(X_EGG);
            ys = sir_surriaafft(y);

            mic_surr_pos_body(s,p,is) = mic_lagged_mine(xs, ys, lag_target_pos);
        
            mic_surr_neg_body(s,p,is) = mic_lagged_mine(xs, ys, lag_target_neg);

        end
    end
end

%monte carlo 

sig_pos_body       = zeros(Nsubj,nPairs);
sig_neg_body       = zeros(Nsubj,nPairs);

for s = 1:Nsubj

    for p = 1:nPairs

        % (EGG -> y)
        real_pos  = mic_max_pos_body(s,p);
        surr_pos  = squeeze(mic_surr_pos_body(s,p,:));

        pval_pos = (sum(surr_pos > real_pos)) / Nsurr;
        sig_pos_body(s,p)  = pval_pos < alpha;

        % (y -> EGG) 
        real_neg  =mic_max_neg_body(s,p);
        surr_neg  = squeeze(mic_surr_neg_body(s,p,:));
 
        pval_neg = (sum(surr_neg > real_neg)) / Nsurr;
        sig_neg_body(s,p)  = pval_neg < alpha;

    end
end

%% median group heart gut

mic_max_pos_sig = mic_max_pos_body;
mic_max_pos_sig(~sig_pos_body) = NaN;

lag_max_pos_sig = lag_max_pos_body;
lag_max_pos_sig(~sig_pos_body) = NaN;

mic_max_neg_sig = mic_max_neg_body;
mic_max_neg_sig(~sig_neg_body) = NaN;

lag_max_neg_sig = lag_max_neg_body;
lag_max_neg_sig(~sig_neg_body) = NaN;

mic_group_median_pos_body = median(mic_max_pos_sig,1,'omitnan');
lag_group_median_pos_body =  round(median(lag_max_pos_sig,1,'omitnan'));

mic_group_median_neg_body = median(mic_max_neg_sig,1,'omitnan');
lag_group_median_neg_body = round(median(lag_max_neg_sig,1,'omitnan'));

subj_sig_pos = any(sig_pos_body, 2);  
subj_sig_neg = any(sig_neg_body, 2);  

% significative subjects

perc_subj_sig_pos = 100 * sum(subj_sig_pos) / Nsubj
perc_subj_sig_neg = 100 * sum(subj_sig_neg) / Nsubj


