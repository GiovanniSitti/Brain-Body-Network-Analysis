delay_eeg_neg = cell(1,nt);

% split brain body delay 

for t = 1:nt

    mic_pos = squeeze(val_sign_all(:,ch_out,t));
    lag_pos = squeeze(delay_real_all(:,ch_out,t));

    mask_pos = mic_pos > 0 & lag_pos > 0;
    delay_eeg_pos{t} = lag_pos(mask_pos);

    mic_neg = squeeze(val_sign_all(:,ch_in,t));
    lag_neg = squeeze(delay_real_all(:,ch_in,t));

    mask_neg = mic_neg > 0 & lag_neg < 0;
    delay_eeg_neg{t} = lag_neg(mask_neg);

end


% split gut heart delay
nPairs = 2;
delay_body_pos = cell(1,nPairs);
delay_body_neg = cell(1,nPairs);

for p = 1:nPairs

    mic_pos = mic_max_pos_sig(:,p);
    lag_pos = lag_max_pos_sig(:,p);

    mask_pos = mic_pos > 0 & lag_pos > 0;
    delay_body_pos{p} = lag_pos(mask_pos);

    mic_neg = mic_max_neg_sig(:,p);
    lag_neg = lag_max_neg_sig(:,p);

    mask_neg = mic_neg > 0 & lag_neg < 0;
    delay_body_neg{p} = lag_neg(mask_neg);

end

